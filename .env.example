# LLM API 설정 (OpenAI SDK 형식을 지원하는 모든 LLM API)
# 알리바바 Bailian 플랫폼의 qwen-plus 모델 권장: https://bailian.console.aliyun.com/
# 소비량이 크므로 먼저 40라운드 미만으로 시뮬레이션을 시도해보세요
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Neo4j 그래프 데이터베이스 설정 =====
# Docker Compose로 로컬 실행 시 기본값 사용 가능
# docker compose up -d 실행 후 http://localhost:7474 에서 확인
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish_password

# ===== 가속 LLM 설정 (선택 사항) =====
# 가속 설정을 사용하지 않는 경우 env 파일에 아래 설정 항목을 포함하지 마세요
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
